---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
---

<BaseLayout title="CV" description="CV page for Amir M. Farid.">
  <div class="page container-narrow stack">
    <SectionHeader
      eyebrow="CV"
      title="Curriculum Vitae"
      summary="A public CV PDF can live at /cv.pdf. The current file is a placeholder until the confirmed CV is added."
    />
    <div class="button-row">
      <a class="button" href="/cv.pdf">Open CV PDF</a>
    </div>
  </div>
</BaseLayout>
