---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PublicationItem from '../components/PublicationItem.astro';
import SectionHeader from '../components/SectionHeader.astro';

const publications = (await getCollection('publications')).sort((a, b) => (b.data.year ?? 0) - (a.data.year ?? 0));
---

<BaseLayout title="Publications" description="Publication list for Amir M. M. Farid.">
  <div class="page container-narrow stack">
    <SectionHeader
      eyebrow="Publications"
      title="Publications"
      summary="Peer-reviewed publications and public preprints. Current systems manuscripts are described on the Projects page until they are publicly available."
    />
    <div class="button-row">
      <a
        class="button secondary"
        href="https://scholar.google.com/citations?user=YsxSn4EAAAAJ&hl=en"
        target="_blank"
        rel="me noopener noreferrer"
      >
        Google Scholar
      </a>
    </div>
    <div class="stack">
      {publications.map((publication) => <PublicationItem {...publication.data} />)}
    </div>
  </div>
</BaseLayout>
