---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProfileLinkIcon from '../components/ProfileLinkIcon.astro';
import ProjectCard from '../components/ProjectCard.astro';
import SectionHeader from '../components/SectionHeader.astro';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
const researchProjects = projects.filter((project) => project.data.category === 'research').slice(0, 2);
const appliedProjects = projects.filter((project) => project.data.category === 'applied');
const profileLinks = [
  { label: 'GitHub', href: 'https://github.com/AmirFarid', icon: 'github', external: true },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/amirmfarid/', icon: 'linkedin', external: true },
  {
    label: 'Google Scholar',
    href: 'https://scholar.google.com/citations?user=YsxSn4EAAAAJ&hl=en',
    icon: 'scholar',
    external: true,
  },
  { label: 'Email', href: 'mailto:amir.m.m.farid@gmail.com', icon: 'email', external: false },
] as const;
---

<BaseLayout
  title="Amir M. M. Farid"
  description="Computer Science graduate student studying trustworthy decentralized intelligence under partial trust."
>
  <section class="hero container hero-with-photo">
    <div class="stack" style="gap: 28px;">
      <div class="stack" style="gap: 14px;">
        <p class="eyebrow">Computer Science Graduate Student · Michigan Technological University</p>
        <h1>Amir M. M. Farid</h1>
        <p class="lead">Trustworthy Decentralized Intelligence</p>
      </div>
      <div class="stack" style="gap: 16px; max-width: 850px;">
        <p>
          I study how decentralized intelligent systems can remain secure, private, verifiable, resilient, and efficient
          when participants and infrastructure are only partially trusted.
        </p>
        <p class="muted">
          My current research foundation is in secure and trustworthy distributed systems, including decentralized
          storage, trusted hardware, authenticated storage, erasure and network coding, and distributed verification. I
          am building from that foundation toward trustworthy decentralized inference and agents, with
          privacy-preserving and post-quantum security as a parallel layer.
        </p>
      </div>
      <div class="button-row">
        <a class="button" href="/research">Research</a>
        <a class="button secondary" href="/publications">Publications</a>
      </div>
    </div>
    <aside class="profile-panel" aria-label="Profile links">
      <img
        class="profile-photo"
        src="https://github.com/AmirFarid.png"
        alt="Amir M. M. Farid"
        width="260"
        height="260"
        loading="eager"
        decoding="async"
      />
      <div class="profile-link-list">
        {
          profileLinks.map((link) => (
            <a
              class={`profile-link profile-link-${link.icon}`}
              href={link.href}
              target={link.external ? '_blank' : undefined}
              rel={link.external ? 'me noopener noreferrer' : undefined}
            >
              <span class="profile-link-mark" aria-hidden="true">
                <ProfileLinkIcon name={link.icon} />
              </span>
              <span>{link.label}</span>
            </a>
          ))
        }
      </div>
    </aside>
  </section>

  <section class="page container stack">
    <SectionHeader
      title="Research Agenda"
      summary="One established foundation, one primary future direction, and one parallel security direction."
    />
    <div class="grid grid-3">
      <article class="card stack" style="gap: 10px;">
        <p class="card-kicker">Foundation · Current Work</p>
        <h3>Secure and Trustworthy Distributed Systems</h3>
        <p class="muted">
          Decentralized infrastructure that preserves integrity, availability, recoverability, and verifiability under
          partial trust.
        </p>
      </article>
      <article class="card stack" style="gap: 10px;">
        <p class="card-kicker">Primary Direction</p>
        <h3>Trustworthy Decentralized AI</h3>
        <p class="muted">
          Decentralized and local inference, verifiable provenance, secure agents, collaborative intelligence, and
          user-controlled AI.
        </p>
      </article>
      <article class="card stack" style="gap: 10px;">
        <p class="card-kicker">Parallel Security Direction</p>
        <h3>Privacy-Preserving and Post-Quantum Security</h3>
        <p class="muted">
          Private computation and verification, crypto-agility, post-quantum authentication and key establishment, and
          long-term confidentiality.
        </p>
      </article>
    </div>
  </section>

  <section class="page container stack">
    <SectionHeader title="Research Trajectory" />
    <div class="trajectory" aria-label="Research trajectory">
      <span>Secure decentralized storage and infrastructure</span>
      <span aria-hidden="true">→</span>
      <span>trustworthy decentralized inference and agents</span>
      <span aria-hidden="true">→</span>
      <span>secure, private, verifiable, resilient decentralized intelligence</span>
    </div>
  </section>

  <section class="page container stack">
    <SectionHeader
      title="Current Research"
      summary="Systems projects that form the current foundation of my broader research agenda."
    />
    <div class="grid grid-2">
      {researchProjects.map((project) => <ProjectCard {...project.data} />)}
    </div>
  </section>

  <section class="page container stack">
    <SectionHeader
      title="Applied AI Security"
      summary="Selected work in LLM security infrastructure, experimentation, and technical education."
    />
    <div class="grid grid-2">
      {appliedProjects.map((project) => <ProjectCard {...project.data} />)}
    </div>
  </section>

  <section class="page container stack">
    <SectionHeader
      title="Writing"
      summary="Short essays on trustworthy systems, research decisions, and building secure infrastructure."
    />
    <a class="card stack writing-link" style="gap: 10px;" href="/blog">
      <p class="card-kicker">Blog</p>
      <h3>Essays and notes</h3>
      <p class="muted">Short essays on trustworthy systems, research decisions, and building secure infrastructure.</p>
    </a>
  </section>
</BaseLayout>
