---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProfileLinkIcon from '../components/ProfileLinkIcon.astro';

const profileLinks = [
  { label: 'GitHub', href: 'https://github.com/AmirFarid', icon: 'github', external: true },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/amirmfarid/', icon: 'linkedin', external: true },
  {
    label: 'Google Scholar',
    href: 'https://scholar.google.com/citations?user=YsxSn4EAAAAJ&hl=en',
    icon: 'scholar',
    external: true,
  },
  { label: 'Email', href: 'mailto:amir.m.m.farid@gmail.com', icon: 'email', external: false },
] as const;
---

<BaseLayout
  title="Amir M. M. Farid"
  description="Amir M. M. Farid studies secure decentralized systems and trustworthy decentralized AI at Michigan Technological University."
>
  <section class="hero container hero-with-photo">
    <div class="stack research-agenda" style="gap: 28px;">
      <div class="stack" style="gap: 14px;">
        <p class="eyebrow">Computer Science Graduate Student - Michigan Technological University</p>
        <h1>Amir M. M. Farid</h1>
      </div>

      <section class="card stack" style="gap: 22px;" aria-labelledby="research-agenda-title">
        <div class="stack" style="gap: 10px;">
          <h2 id="research-agenda-title">Research Agenda</h2>
          <h3>Trustworthy Decentralized Intelligence</h3>
          <p>
            I study how decentralized intelligent systems can remain secure, verifiable, resilient, and efficient when
            participants and infrastructure cannot be fully trusted.
          </p>
        </div>

        <div class="grid grid-2">
          <article class="stack" style="gap: 8px;">
            <h4 class="card-kicker">Current Foundation</h4>
            <p><strong>Secure and Trustworthy Distributed Systems</strong></p>
            <p class="muted">
              My current work focuses on decentralized storage and infrastructure that preserve integrity, availability,
              recoverability, and verifiability under partial trust.
            </p>
          </article>

          <article class="stack" style="gap: 8px;">
            <h4 class="card-kicker">Primary Direction</h4>
            <p><strong>Trustworthy Decentralized AI</strong></p>
            <p class="muted">
              I am extending this systems foundation toward decentralized and local inference, verifiable provenance,
              secure agents, collaborative intelligence, and user-controlled AI.
            </p>
          </article>
        </div>

        <div class="stack" style="gap: 10px;">
          <h4 class="card-kicker">Research Trajectory</h4>
          <div class="trajectory compact-trajectory" aria-label="Research trajectory">
            <strong>Secure decentralized infrastructure</strong>
            <span aria-hidden="true">→</span>
            <strong>trustworthy decentralized inference and agents</strong>
            <span aria-hidden="true">→</span>
            <strong>secure, private, and verifiable decentralized intelligence</strong>
          </div>
        </div>
      </section>
    </div>

    <aside class="profile-panel" aria-label="Profile links">
      <img
        class="profile-photo"
        src="https://github.com/AmirFarid.png"
        alt="Amir M. M. Farid"
        width="260"
        height="260"
        loading="eager"
        decoding="async"
      />
      <div class="profile-link-list">
        {
          profileLinks.map((link) => (
            <a
              class={`profile-link profile-link-${link.icon}`}
              href={link.href}
              aria-label={link.label}
              title={link.label}
              target={link.external ? '_blank' : undefined}
              rel={link.external ? 'me noopener noreferrer' : undefined}
            >
              <span class="profile-link-mark" aria-hidden="true">
                <ProfileLinkIcon name={link.icon} />
              </span>
            </a>
          ))
        }
      </div>
    </aside>
  </section>
</BaseLayout>
