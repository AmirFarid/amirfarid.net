---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProfileLinkIcon from '../components/ProfileLinkIcon.astro';
import { manualTimelineEntries } from '../data/timeline';

const profileLinks = [
  { label: 'GitHub', href: 'https://github.com/AmirFarid', icon: 'github', external: true },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/amirmfarid/', icon: 'linkedin', external: true },
  {
    label: 'Google Scholar',
    href: 'https://scholar.google.com/citations?user=YsxSn4EAAAAJ&hl=en',
    icon: 'scholar',
    external: true,
  },
  { label: 'Email', href: 'mailto:amir.m.m.farid@gmail.com', icon: 'email', external: false },
] as const;

const posts = (await getCollection('blog')).filter((post) => !post.data.draft);
const publications = await getCollection('publications');

type TimelineEntry = {
  id: string;
  displayDate: string;
  datetime: string;
  sortDate: string;
  category: 'Education' | 'Mentoring' | 'Service' | 'Post' | 'Publication';
  content: string;
  link?: {
    href: string;
    text: string;
  };
  suffix?: string;
};

const postTimelineEntries: TimelineEntry[] = posts.map((post) => ({
  id: `post-${post.slug}`,
  displayDate: formatDate(post.data.date),
  datetime: post.data.date.toISOString().slice(0, 10),
  sortDate: post.data.date.toISOString().slice(0, 10),
  category: 'Post',
  content: 'Published:',
  link: {
    href: `/blog/${post.slug}`,
    text: post.data.title,
  },
}));

const publicationTimelineEntries: TimelineEntry[] = publications
  .filter((publication) => publication.data.year)
  .map((publication) => {
    const titleLink = publication.data.links[0]?.url;
    const title = publication.data.title;
    const venue = publication.data.venue;
    const authors = publication.data.authors.join(', ');
    const status = publication.data.status;

    return {
      id: `publication-${publication.id}`,
      displayDate: String(publication.data.year),
      datetime: String(publication.data.year),
      sortDate: `${publication.data.year}-01-01`,
      category: 'Publication',
      content:
        status === 'Published'
          ? 'Published'
          : status === 'Preprint'
            ? 'Preprint:'
            : `${status}:`,
      link: titleLink ? { href: titleLink, text: title } : undefined,
      suffix: `${titleLink ? '' : title}${status === 'Published' && venue ? ` in ${venue}` : venue ? ` — ${venue}` : ''}. Authors: ${authors}`,
    };
  });

const timelineEntries: TimelineEntry[] = [
  ...manualTimelineEntries.map((entry) => ({
    ...entry,
    content: entry.text,
  })),
  ...postTimelineEntries,
  ...publicationTimelineEntries,
].sort((a, b) => b.sortDate.localeCompare(a.sortDate));

const newsPageSize = 7;
const newsPageCount = Math.ceil(timelineEntries.length / newsPageSize);

function formatDate(date: Date) {
  return new Intl.DateTimeFormat('en', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
    timeZone: 'UTC',
  }).format(date);
}
---

<BaseLayout
  title="Amir M. M. Farid"
  description="Amir M. M. Farid is a computer science researcher at Michigan Technological University working on secure and trustworthy decentralized systems and trustworthy decentralized AI."
>
  <div class="page container stack landing-page">
    <section class="hero hero-with-photo landing-identity" aria-labelledby="landing-title">
      <div class="stack" style="gap: 18px;">
        <h1 id="landing-title">Amir M. M. Farid</h1>
      </div>
      <aside class="profile-panel" aria-label="Profile image">
        <img
          class="profile-photo"
          src="https://github.com/AmirFarid.png"
          alt="Amir M. M. Farid"
          width="260"
          height="260"
          loading="eager"
          decoding="async"
        />
      </aside>
    </section>

    <section class="card stack" aria-labelledby="about-title">
      <h2 id="about-title">About</h2>
      <div class="prose">
        <p>
          I am a computer science graduate student in the
          <a href="https://www.mtu.edu/cs/" target="_blank" rel="noopener noreferrer"
            ><strong>Department of Computer Science</strong></a
          >
          at Michigan Technological University, where I work with
          <a href="https://pages.mtu.edu/~bchen/" target="_blank" rel="noopener noreferrer"><strong>Dr. Bo Chen</strong></a>
          on secure and trustworthy decentralized systems. I joined Michigan Tech in Spring 2025 and expect to complete
          my M.S. in Computer Science in Fall 2026.
        </p>
        <p>
          Before joining Michigan Tech, I earned my B.S. in Computer Engineering from
          <a href="https://azad.ac.ir/" target="_blank" rel="noopener noreferrer"
            ><strong>Islamic Azad University</strong></a
          >
          and worked with
          <a href="https://orcid.org/0000-0002-9812-1331" target="_blank" rel="noopener noreferrer"
            ><strong>Dr. Mostafa Haghi Kashani</strong></a
          >
          on fog computing and IoT-enabled smart cities. Outside research, I enjoy biking and reading.
        </p>
        <h2 id="research-agenda-title">Research Agenda</h2>
        <h3>Trustworthy Decentralized Intelligence</h3>
        <p>
          I study how decentralized intelligent systems can remain secure, verifiable, resilient, and efficient when
          participants and infrastructure cannot be fully trusted.
        </p>
        <p><strong>Current Foundation — Secure and Trustworthy Distributed Systems</strong></p>
        <p>
          My current work focuses on decentralized storage and infrastructure that preserve integrity, availability,
          recoverability, and verifiability under partial trust.
        </p>
        <p><strong>Primary Direction — Trustworthy Decentralized AI</strong></p>
        <p>
          I am extending this systems foundation toward decentralized and local inference, verifiable provenance, secure
          agents, collaborative intelligence, and user-controlled AI.
        </p>
        <p><strong>Research Trajectory</strong></p>
        <p>
          <strong>Secure decentralized infrastructure</strong><br />
          → <strong>Trustworthy decentralized inference and agents</strong><br />
          → <strong>Secure, private, and verifiable decentralized intelligence</strong>
        </p>
      </div>
    </section>

    <section class="stack" aria-labelledby="timeline-title">
      <h2 id="timeline-title" tabindex="-1">News and Milestones</h2>
      <ol class="timeline-list" data-news-list data-page-size={newsPageSize}>
        {
          timelineEntries.map((entry, index) => (
            <li
              class="timeline-item"
              data-news-entry
              data-news-index={index}
              hidden={index >= newsPageSize}
              data-page-last={index === Math.min(newsPageSize, timelineEntries.length) - 1 ? 'true' : undefined}
            >
              <time datetime={entry.datetime}>{entry.displayDate}</time>
              <p class="timeline-content">
                <span class="timeline-category">{entry.category}</span>
                <span>
                  {entry.content}
                  {entry.link && (
                    <>
                      {' '}
                      <a href={entry.link.href}>{entry.link.text}</a>
                    </>
                  )}
                  {entry.suffix}
                </span>
              </p>
            </li>
          ))
        }
      </ol>
      {
        newsPageCount > 1 && (
          <nav class="news-pagination" aria-label="News pagination" data-news-pagination data-page-count={newsPageCount}>
            <a
              class="news-page-link"
              href="?newsPage=1"
              aria-label="Previous news page"
              aria-disabled="true"
              tabindex="-1"
              data-news-prev
            >
              Previous
            </a>
            <div class="news-page-numbers" aria-label="News pages">
              {Array.from({ length: newsPageCount }, (_, index) => {
                const page = index + 1;
                return (
                  <a
                    class="news-page-link"
                    href={`?newsPage=${page}`}
                    aria-label={`News page ${page}`}
                    aria-current={page === 1 ? 'page' : undefined}
                    data-news-page={page}
                  >
                    {page}
                  </a>
                );
              })}
            </div>
            <a class="news-page-link" href="?newsPage=2" aria-label="Next news page" data-news-next>
              Next
            </a>
          </nav>
        )
      }
    </section>

    <nav class="profile-link-list landing-social-links" aria-label="Profile links">
      {
        profileLinks.map((link) => (
          <a
            class={`profile-link profile-link-${link.icon}`}
            href={link.href}
            aria-label={link.label}
            title={link.label}
            target={link.external ? '_blank' : undefined}
            rel={link.external ? 'me noopener noreferrer' : undefined}
          >
            <span class="profile-link-mark" aria-hidden="true">
              <ProfileLinkIcon name={link.icon} />
            </span>
          </a>
        ))
      }
    </nav>
  </div>
  <script>
    const newsList = document.querySelector<HTMLElement>('[data-news-list]');
    const newsPagination = document.querySelector<HTMLElement>('[data-news-pagination]');
    const timelineTitle = document.querySelector<HTMLElement>('#timeline-title');

    if (newsList && newsPagination && timelineTitle) {
      const pageSize = Number(newsList.getAttribute('data-page-size'));
      const pageCount = Number(newsPagination.getAttribute('data-page-count'));
      const entries = Array.from(newsList.querySelectorAll<HTMLElement>('[data-news-entry]'));
      const pageLinks = Array.from(newsPagination.querySelectorAll<HTMLAnchorElement>('[data-news-page]'));
      const previousLink = newsPagination.querySelector<HTMLAnchorElement>('[data-news-prev]');
      const nextLink = newsPagination.querySelector<HTMLAnchorElement>('[data-news-next]');

      const getPageFromUrl = () => {
        const page = Number(new URLSearchParams(window.location.search).get('newsPage') || '1');
        return Number.isInteger(page) ? Math.min(Math.max(page, 1), pageCount) : 1;
      };

      const pageUrl = (page: number) => {
        const url = new URL(window.location.href);
        if (page <= 1) {
          url.searchParams.delete('newsPage');
        } else {
          url.searchParams.set('newsPage', String(page));
        }
        return `${url.pathname}${url.search}${url.hash}`;
      };

      const updateEdgeLink = (link: HTMLAnchorElement | null, page: number, disabled: boolean) => {
        if (!link) return;
        link.setAttribute('href', pageUrl(page));
        link.setAttribute('aria-disabled', String(disabled));
        if (disabled) {
          link.setAttribute('tabindex', '-1');
        } else {
          link.removeAttribute('tabindex');
        }
      };

      const showPage = (page: number, moveFocus = false) => {
        const start = (page - 1) * pageSize;
        const end = start + pageSize;
        const lastVisible = entries.slice(start, end).at(-1);

        entries.forEach((entry, index) => {
          const visible = index >= start && index < end;
          entry.hidden = !visible;
          entry.removeAttribute('data-page-last');
        });

        if (lastVisible) {
          lastVisible.setAttribute('data-page-last', 'true');
        }

        pageLinks.forEach((link) => {
          const linkPage = Number(link.getAttribute('data-news-page'));
          link.setAttribute('href', pageUrl(linkPage));
          if (linkPage === page) {
            link.setAttribute('aria-current', 'page');
          } else {
            link.removeAttribute('aria-current');
          }
        });

        updateEdgeLink(previousLink, Math.max(page - 1, 1), page === 1);
        updateEdgeLink(nextLink, Math.min(page + 1, pageCount), page === pageCount);

        if (moveFocus) {
          timelineTitle.scrollIntoView({ behavior: 'smooth', block: 'start' });
          timelineTitle.focus({ preventScroll: true });
        }
      };

      newsPagination.addEventListener('click', (event) => {
        const target = event.target instanceof Element ? event.target : null;
        const link = target?.closest<HTMLAnchorElement>('a');
        if (!link || link.getAttribute('aria-disabled') === 'true') return;
        event.preventDefault();
        const url = new URL(link.href);
        window.history.pushState({}, '', `${url.pathname}${url.search}${url.hash}`);
        showPage(getPageFromUrl(), true);
      });

      window.addEventListener('popstate', () => showPage(getPageFromUrl(), true));
      showPage(getPageFromUrl());
    }
  </script>
</BaseLayout>
