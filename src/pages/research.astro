---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';

const interests = [
  'Security, privacy, and reliability for decentralized systems',
  'Decentralized storage and distributed repair',
  'Decentralized inference and AI-assisted security',
  'Edge, IoT, and connected infrastructure security',
  'Trusted hardware and trusted execution environments',
  'Storage-layer and file-system-aware security mechanisms',
  'Post-quantum-aware decentralized system design',
];

const technicalAreas =
  'C/C++ · Python · Linux · Systems Security · Distributed Systems · Decentralized Systems · Storage Systems · Edge/IoT Security · Trusted Hardware · SGX · SEV · TDX · Erasure Coding · Network Coding · LLMs';
---

<BaseLayout title="Research" description="Research overview and themes for Amir M. M. Farid.">
  <div class="page container stack">
    <SectionHeader
      eyebrow="Research"
      title="Secure, private, and reliable decentralized systems"
      summary="My research focuses on secure, private, and reliable decentralized systems."
    />

    <section class="prose">
      <p>
        I am interested in how decentralized infrastructures can operate under partial trust, failures, and adversarial
        behavior. This includes systems where data, computation, inference, and control are distributed across many
        components, such as storage nodes, edge devices, IoT systems, and untrusted execution environments.
      </p>
    </section>

    <section class="prose">
      <h2>Research Direction</h2>
      <p>
        My current research studies decentralized systems that combine trusted hardware, erasure and network coding,
        distributed repair, and storage-layer mechanisms to improve integrity, availability, and recoverability without
        relying on fully trusted infrastructure.
      </p>
      <p>
        I am also interested in decentralized inference and AI-assisted security mechanisms, especially how LLMs and AI
        agents can help detect, reason about, and mitigate malicious or unsafe behavior in connected and distributed
        environments.
      </p>
    </section>

    <section class="stack">
      <h2>Core Interests</h2>
      <div class="grid grid-3">
        {interests.map((interest) => (
          <article class="card">
            <h3>{interest}</h3>
          </article>
        ))}
      </div>
    </section>

    <section class="prose">
      <h2>Technical Areas</h2>
      <p>{technicalAreas}</p>
    </section>
  </div>
</BaseLayout>
