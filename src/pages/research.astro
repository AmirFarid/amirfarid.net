---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PublicationItem from '../components/PublicationItem.astro';
import SectionHeader from '../components/SectionHeader.astro';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
const currentResearchProjects = projects.filter((project) => project.data.category === 'research');
const publications = (await getCollection('publications')).sort((a, b) => (b.data.year ?? 0) - (a.data.year ?? 0));

const researchInterests = [
  'Secure and trustworthy decentralized systems',
  'Trustworthy decentralized AI',
  'Privacy-preserving and verifiable computation',
];

const publicationGroups = [
  {
    title: 'Journal Articles',
    items: publications.filter((publication) => publication.data.status === 'Published'),
  },
  {
    title: 'Preprints',
    items: publications.filter((publication) => publication.data.status === 'Preprint'),
  },
].filter((group) => group.items.length > 0);
---

<BaseLayout
  title="Research"
  description="Research and publications by Amir M. M. Farid on secure decentralized systems and trustworthy decentralized AI."
>
  <div class="page container stack">
    <SectionHeader
      eyebrow="Research"
      title="Trustworthy Decentralized Intelligence"
      summary="Secure decentralized systems -> trustworthy decentralized AI."
    />

    <section class="prose">
      <p>
        I study how decentralized systems can remain secure, verifiable, resilient, and efficient when participants and
        infrastructure cannot be fully trusted.
      </p>
      <p>
        My current research focuses on secure decentralized storage and trustworthy distributed infrastructure, including
        trusted hardware, authenticated storage, distributed repair, and coding-based reliability.
      </p>
      <p>
        Building on this systems foundation, I am moving toward trustworthy decentralized AI, with particular interest in
        decentralized inference, verifiable computation and provenance, privacy-preserving coordination, and secure
        intelligent agents.
      </p>
    </section>

    <section class="stack">
      <h2>Research Interests</h2>
      <div class="grid grid-3">
        {
          researchInterests.map((interest) => (
            <article class="card stack" style="gap: 8px;">
              <h3>{interest}</h3>
            </article>
          ))
        }
      </div>
    </section>

    <section class="stack">
      <h2>Current Research</h2>
      <div class="grid grid-2">
        {
          currentResearchProjects.map((project) => (
            <article class="card stack" style="gap: 8px;">
              <h3>{project.data.title}</h3>
              <p class="muted">{project.data.summary}</p>
              <p><strong>{project.data.status}</strong></p>
              {project.data.links.length > 0 && (
                <div class="button-row">
                  {project.data.links.map((link) => (
                    <a class="button secondary" href={link.url}>
                      {link.label}
                    </a>
                  ))}
                </div>
              )}
            </article>
          ))
        }
      </div>
    </section>

    <section class="stack">
      <h2>Trajectory</h2>
      <div class="trajectory" aria-label="Research trajectory">
        <span>Secure decentralized systems</span>
        <span aria-hidden="true">-&gt;</span>
        <span>trustworthy decentralized AI</span>
      </div>
    </section>

    <section id="publications" class="stack">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Publications</p>
          <h2>Publications</h2>
        </div>
        <a
          class="button secondary"
          href="https://scholar.google.com/citations?user=YsxSn4EAAAAJ&hl=en"
          target="_blank"
          rel="me noopener noreferrer"
        >
          Google Scholar
        </a>
      </div>
      {
        publicationGroups.map((group) => (
          <section class="stack" style="gap: 14px;">
            <h3>{group.title}</h3>
            <div class="stack" style="gap: 14px;">
              {group.items.map((publication) => (
                <PublicationItem {...publication.data} />
              ))}
            </div>
          </section>
        ))
      }
    </section>
  </div>
</BaseLayout>
