---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Analytics from '../components/Analytics.astro';
import { siteMetadata } from '../config/site';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
  image?: string;
  ogType?: 'website' | 'article';
}

const siteTitle = siteMetadata.title;
const siteUrl = siteMetadata.url.replace(/\/$/, '');
const {
  title = siteTitle,
  description = siteMetadata.description,
  noindex = false,
  image = siteMetadata.profileImage,
  ogType = 'website',
} = Astro.props;
const fullTitle = title === siteTitle ? siteTitle : `${title} | ${siteTitle}`;
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const imageUrl = image.startsWith('http') ? image : new URL(image, siteUrl).toString();
const isHomePage = Astro.url.pathname === '/';
const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    '@id': `${siteUrl}/#person`,
    name: siteMetadata.name,
    alternateName: siteMetadata.alternateNames,
    url: new URL('/', siteUrl).toString(),
    image: siteMetadata.profileImage,
    sameAs: siteMetadata.sameAs,
    description: siteMetadata.description,
    jobTitle: siteMetadata.role,
    affiliation: {
      '@type': 'CollegeOrUniversity',
      name: siteMetadata.affiliation,
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    '@id': `${siteUrl}/#website`,
    name: siteMetadata.name,
    alternateName: siteMetadata.alternateNames,
    url: new URL('/', siteUrl).toString(),
    description: siteMetadata.description,
    publisher: {
      '@id': `${siteUrl}/#person`,
    },
  },
  ...(isHomePage
    ? [
        {
          '@context': 'https://schema.org',
          '@type': 'ProfilePage',
          '@id': `${siteUrl}/#profile`,
          url: new URL('/', siteUrl).toString(),
          name: siteMetadata.name,
          description,
          mainEntity: {
            '@id': `${siteUrl}/#person`,
          },
          isPartOf: {
            '@id': `${siteUrl}/#website`,
          },
        },
      ]
    : []),
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="author" content={siteMetadata.author} />
    <meta name="keywords" content={siteMetadata.keywords.join(', ')} />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:site_name" content={siteMetadata.name} />
    <meta property="og:locale" content={siteMetadata.locale} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <title>{fullTitle}</title>
    <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    <Analytics />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
