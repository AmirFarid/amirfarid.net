---
import BaseLayout from './BaseLayout.astro';
import TagList from '../components/TagList.astro';

interface Props {
  title: string;
  summary: string;
  date: Date;
  updated?: Date;
  level: string;
  prerequisites?: string[];
  tags?: string[];
  interactive?: boolean;
}

const { title, summary, date, updated, level, prerequisites = [], tags = [], interactive = false } = Astro.props;
const formatDate = (value: Date) =>
  value.toLocaleDateString('en', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={title} description={summary}>
  <article class="page container-narrow">
    <header class="stack" style="gap: 16px; margin-bottom: 34px;">
      <p class="eyebrow">Learning Note</p>
      <h1>{title}</h1>
      <p class="lead">{summary}</p>
      <div class="meta">
        <time datetime={date.toISOString()}>{formatDate(date)}</time>
        {updated && <span>Updated {formatDate(updated)}</span>}
        <span>Level: {level}</span>
        {interactive && <span>Interactive-ready</span>}
      </div>
      {prerequisites.length > 0 && <p class="muted"><strong>Prerequisites:</strong> {prerequisites.join(', ')}</p>}
      <TagList tags={tags} />
    </header>
    <!-- Future interactive MDX teaching components can be embedded inside learning posts here. -->
    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>
