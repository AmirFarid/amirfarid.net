---
import BaseLayout from './BaseLayout.astro';
import TagList from '../components/TagList.astro';

interface Props {
  title: string;
  summary: string;
  date: Date;
  updated?: Date;
  tags?: string[];
  eyebrow: string;
  details?: string[];
}

const { title, summary, date, updated, tags = [], eyebrow, details = [] } = Astro.props;
const formatDate = (value: Date) =>
  value.toLocaleDateString('en', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={title} description={summary}>
  <article class="page container-narrow">
    <header class="stack" style="gap: 16px; margin-bottom: 34px;">
      <p class="eyebrow">{eyebrow}</p>
      <h1>{title}</h1>
      <p class="lead">{summary}</p>
      <div class="meta">
        <time datetime={date.toISOString()}>{formatDate(date)}</time>
        {updated && <span>Updated {formatDate(updated)}</span>}
        {details.map((detail) => <span>{detail}</span>)}
      </div>
      <TagList tags={tags} />
    </header>
    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>
