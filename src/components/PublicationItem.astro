---
interface Link {
  label: string;
  url: string;
}

interface Props {
  title: string;
  authors: string[];
  venue?: string;
  status: string;
  year?: number;
  links?: Link[];
}

const { title, authors, venue, status, year, links = [] } = Astro.props;
const details = [status, venue, year].filter(Boolean).join(' · ');

function displayAuthor(author: string) {
  if (/^(AMM Farid|AM MoghadamFarid)$/i.test(author)) {
    return 'Amirmehdi Moghadamfarid';
  }

  return author;
}
---

<article class="card stack" style="gap: 10px;">
  <h3>{title}</h3>
  <p class="muted">
    {
      authors.map((author, index) => (
        <>
          {index > 0 && ', '}
          {displayAuthor(author) === 'Amirmehdi Moghadamfarid' ? <strong>{displayAuthor(author)}</strong> : displayAuthor(author)}
        </>
      ))
    }
  </p>
  <p><strong>{details}</strong></p>
  {links.length > 0 && (
    <div class="button-row">
      {links.map((link) => (
        <a class="button secondary" href={link.url}>{link.label}</a>
      ))}
    </div>
  )}
</article>
