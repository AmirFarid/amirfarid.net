---
import TagList from './TagList.astro';

interface Props {
  href: string;
  title: string;
  summary: string;
  date: Date;
  tags?: string[];
  badge?: string;
  image?: {
    src: string;
    alt: string;
  };
}

const { href, title, summary, date, tags = [], badge, image } = Astro.props;
const formattedDate = date.toLocaleDateString('en', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class="card stack" style="gap: 13px;">
  {
    image && (
      <a href={href} aria-label={title}>
        <img class="card-image" src={image.src} alt={image.alt} loading="lazy" decoding="async" />
      </a>
    )
  }
  <div class="meta">
    <time datetime={date.toISOString()}>{formattedDate}</time>
    {badge && <span>{badge}</span>}
  </div>
  <h3><a href={href}>{title}</a></h3>
  <p class="muted">{summary}</p>
  <TagList tags={tags} />
</article>
