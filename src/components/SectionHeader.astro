---
interface Props {
  eyebrow?: string;
  title: string;
  summary?: string;
}

const { eyebrow, title, summary } = Astro.props;
---

<header class="stack" style="gap: 10px;">
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h2>{title}</h2>
  {summary && <p class="lead">{summary}</p>}
</header>
