---
interface Props {
  name: 'cv' | 'github' | 'linkedin' | 'scholar' | 'email';
}

const { name } = Astro.props;
---

{
  name === 'cv' && (
    <svg class="profile-link-icon" viewBox="0 0 24 24" aria-hidden="true">
      <path
        d="M6.5 3.5h7.2l3.8 3.8v13.2h-11V3.5Z"
        fill="none"
        stroke="currentColor"
        stroke-linejoin="round"
        stroke-width="1.9"
      />
      <path d="M13.5 3.8v3.9h3.8" fill="none" stroke="currentColor" stroke-linejoin="round" stroke-width="1.9" />
      <path d="M8.8 12h6.4M8.8 15.2h5.2" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.9" />
    </svg>
  )
}
{
  name === 'github' && (
    <svg class="profile-link-icon" viewBox="0 0 24 24" aria-hidden="true">
      <path
        fill="currentColor"
        d="M12 .5C5.65.5.5 5.65.5 12c0 5.09 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56v-2.14c-3.2.7-3.87-1.36-3.87-1.36-.52-1.33-1.28-1.68-1.28-1.68-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.76 2.7 1.25 3.36.96.1-.75.4-1.25.73-1.54-2.55-.29-5.24-1.28-5.24-5.68 0-1.25.45-2.28 1.19-3.08-.12-.29-.52-1.46.11-3.04 0 0 .97-.31 3.17 1.18A10.98 10.98 0 0 1 12 6.07c.98 0 1.95.13 2.87.39 2.2-1.49 3.17-1.18 3.17-1.18.63 1.58.23 2.75.11 3.04.74.8 1.19 1.83 1.19 3.08 0 4.41-2.69 5.38-5.25 5.67.41.36.78 1.06.78 2.14v3.14c0 .31.21.67.8.56A11.51 11.51 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z"
      />
    </svg>
  )
}
{
  name === 'email' && (
    <svg class="profile-link-icon" viewBox="0 0 24 24" aria-hidden="true">
      <path
        d="M3.8 6.2h16.4v11.6H3.8V6.2Z"
        fill="none"
        stroke="currentColor"
        stroke-linejoin="round"
        stroke-width="1.9"
      />
      <path d="m4.4 6.8 7.6 6 7.6-6" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.9" />
    </svg>
  )
}
{
  name === 'linkedin' && (
    <svg class="profile-link-icon" viewBox="0 0 24 24" aria-hidden="true">
      <path
        fill="currentColor"
        d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.13 1.44-2.13 2.94v5.67H9.36V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28ZM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12ZM7.12 20.45H3.56V9h3.56v11.45ZM22.23 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.23 0Z"
      />
    </svg>
  )
}
{
  name === 'scholar' && (
    <svg class="profile-link-icon" viewBox="0 0 24 24" aria-hidden="true">
      <path fill="currentColor" d="M12 2 1.6 10.1 12 18.2l10.4-8.1L12 2Z" />
      <path fill="currentColor" d="M5.9 15.2a6.1 6.1 0 1 0 12.2 0 6.1 6.1 0 0 0-12.2 0Z" />
      <path fill="#ffffff" d="M8.7 15.2a3.3 3.3 0 1 0 6.6 0 3.3 3.3 0 0 0-6.6 0Z" />
    </svg>
  )
}
